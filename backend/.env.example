# =====================================================
# SERVER CONFIGURATION
# =====================================================
PORT=8080
SERVER_PORT=8080
APP_NAME=jewelry-ecommerce
FRONTEND_URL=http://localhost:5173

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
DATABASE_URL=jdbc:mysql://localhost:3306/jewelry_ecommerce?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USERNAME=root
DATABASE_PASSWORD=
DDL_AUTO=update
DB_MIN_IDLE=5
DB_MAX_POOL_SIZE=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# =====================================================
# JWT CONFIGURATION
# =====================================================
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION=86400000

# =====================================================
# RAZORPAY CONFIGURATION
# =====================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# =====================================================
# LOGGING / DOCS
# =====================================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
API_DOCS_ENABLED=true
SWAGGER_UI_ENABLED=true

# =====================================================
# CLOUDINARY CONFIGURATION
# =====================================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =====================================================
# FILE UPLOAD SETTINGS
# =====================================================
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=50MB

# =====================================================
# MAIL PROVIDER CONFIGURATION
# =====================================================
# Use a transactional email provider API key here.
# For local testing with Brevo, keep MAIL_PROVIDER=brevo and set MAIL_FROM_EMAIL to a verified sender.
MAIL_PROVIDER=brevo
MAIL_API_KEY=
MAIL_FROM_NAME=Luxury Maison
MAIL_FROM_EMAIL=no-reply@yourdomain.com
MAIL_ENABLED=true
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_SMTP_SSL_ENABLE=false
MAIL_STARTTLS_ENABLE=false
MAIL_SMTP_AUTH=false
MAIL_CONNECTION_TIMEOUT=5000
MAIL_TIMEOUT=5000
MAIL_WRITE_TIMEOUT=5000
MAIL_DEBUG=false

# =====================================================
# DIRECT PAYMENT CONFIGURATION
# =====================================================
PAYMENT_UPI_ID=
PAYMENT_UPI_PAYEE_NAME=
